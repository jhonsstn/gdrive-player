generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Series {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seasons   Season[]
}

model Season {
  id           String   @id @default(cuid())
  seriesId     String
  folderId     String   @unique
  seasonNumber Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  series       Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, seasonNumber])
  @@index([seriesId])
}

model ConfiguredFolder {
  id        String   @id @default(cuid())
  folderId  String   @unique
  name      String?
  sourceUrl String
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FolderVideo {
  id           String    @id @default(cuid())
  folderId     String
  driveFileId  String
  name         String
  mimeType     String
  size         String?
  modifiedTime DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  watchProgress WatchProgress[]

  @@unique([folderId, driveFileId])
  @@index([folderId])
}

model WatchProgress {
  id            String       @id @default(cuid())
  userEmail     String
  folderVideoId String?
  currentTime   Float        @default(0)
  duration      Float        @default(0)
  watched       Boolean      @default(false)
  updatedAt     DateTime     @updatedAt

  folderVideo   FolderVideo? @relation(fields: [folderVideoId], references: [id], onDelete: Cascade)

  @@unique([userEmail, folderVideoId])
}

model UserFolderLastSeen {
  id             String    @id @default(cuid())
  userEmail      String
  folderId       String
  lastSeenDate   DateTime
  watchedThrough DateTime?
  updatedAt      DateTime  @updatedAt

  @@unique([userEmail, folderId])
}

