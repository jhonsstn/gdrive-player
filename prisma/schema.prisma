generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model ConfiguredFolder {
  id        String   @id @default(cuid())
  folderId  String   @unique
  name      String?
  sourceUrl String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WatchProgress {
  id          String   @id @default(cuid())
  userEmail   String
  videoId     String
  currentTime Float    @default(0)
  duration    Float    @default(0)
  watched     Boolean  @default(false)
  folderId    String?
  videoName   String?
  updatedAt   DateTime @updatedAt

  @@unique([userEmail, videoId])
}

model UserFolderLastSeen {
  id             String    @id @default(cuid())
  userEmail      String
  folderId       String
  lastSeenDate   DateTime
  watchedThrough DateTime?
  updatedAt      DateTime  @updatedAt

  @@unique([userEmail, folderId])
}

